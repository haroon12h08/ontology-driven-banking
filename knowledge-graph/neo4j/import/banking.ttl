@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sbi: <http://sbi.co.in/ontology/banking#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://sbi.co.in/ontology/banking> a owl:Ontology ;
    rdfs:label "SBI Enterprise Banking Ontology" ;
    rdfs:comment "A production-quality OWL 2 DL ontology representing the conceptual domain model of a cognitive enterprise banking platform. Designed for AI agents reasoning over customer profiles, financial goals, loans, risk, fraud, and banking operations." ;
    owl:versionInfo "1.0.0" .

sbi:ATM a owl:Class ;
    rdfs:label "ATM" ;
    rdfs:comment "Automated cash distributor hardware terminals." .

sbi:AmortizationSchedule a owl:Class ;
    rdfs:label "Amortization Schedule" ;
    rdfs:comment "Timeline chart mapping principal and interest payments." .

sbi:AssetClass a owl:Class ;
    rdfs:label "Asset Class" ;
    rdfs:comment "Taxonomy grouping of securities (e.g., Equity, Fixed Income)." .

sbi:AutoLoan a owl:Class ;
    rdfs:label "Auto Loan" ;
    rdfs:comment "A vehicle-secured installment loan." ;
    rdfs:subClassOf sbi:Loan .

sbi:BillingStatement a owl:Class ;
    rdfs:label "Billing Statement" ;
    rdfs:comment "Monthly revolving credit statements summarizing outstanding debt." .

sbi:CheckingAccount a owl:Class ;
    rdfs:label "Checking Account" ;
    rdfs:comment "A transactional deposit account." ;
    rdfs:subClassOf sbi:DepositAccount .

sbi:CreditLimitPolicy a owl:Class ;
    rdfs:label "Credit Limit Policy" ;
    rdfs:comment "Revolving credit line rules." ;
    rdfs:subClassOf sbi:Policy .

sbi:CreditTransaction a owl:Class ;
    rdfs:label "Credit Transaction" ;
    rdfs:comment "Fund inflow to an account." ;
    rdfs:subClassOf sbi:Transaction .

sbi:CustomerFeedback a owl:Class ;
    rdfs:label "Customer Feedback" ;
    rdfs:comment "Customer reviews, complaints, and feedback records." .

sbi:CustomerJourney a owl:Class ;
    rdfs:label "Customer Journey" ;
    rdfs:comment "Customer lifecycle maps." .

sbi:DebitTransaction a owl:Class ;
    rdfs:label "Debit Transaction" ;
    rdfs:comment "Fund outflow from an account." ;
    rdfs:subClassOf sbi:Transaction .

sbi:DeviceContext a owl:Class ;
    rdfs:label "Device Context" ;
    rdfs:comment "Hardware parameters capturing client terminals." .

sbi:DigitalSignature a owl:Class ;
    rdfs:label "Digital Signature" ;
    rdfs:comment "Cryptographic audit traces confirming legal consent." .

sbi:DocumentType a owl:Class ;
    rdfs:label "Document Type" ;
    rdfs:comment "Classifications mapping compliance retention spans." .

sbi:EngagementCampaign a owl:Class ;
    rdfs:label "Engagement Campaign" ;
    rdfs:comment "Marketing campaigns targeting segments of clients." .

sbi:EventPayload a owl:Class ;
    rdfs:label "Event Payload" ;
    rdfs:comment "Data content structures mapped to events." .

sbi:EventTopic a owl:Class ;
    rdfs:label "Event Topic" ;
    rdfs:comment "Event distribution categories (e.g., CardEvents, TransactionEvents)." .

sbi:FinancialMetric a owl:Class ;
    rdfs:label "Financial Metric" ;
    rdfs:comment "Underlying math balances (e.g., Debt-to-Income, Savings Rate)." .

sbi:FraudPattern a owl:Class ;
    rdfs:label "Fraud Pattern" ;
    rdfs:comment "Signatures and heuristics of known malicious schemes." .

sbi:GoalMilestone a owl:Class ;
    rdfs:label "Goal Milestone" ;
    rdfs:comment "Interim target achievements on the path to goal completion." .

sbi:GoalType a owl:Class ;
    rdfs:label "Goal Type" ;
    rdfs:comment "Controlled category classifications for goals (e.g., Retirement, Education)." .

sbi:HomeLoan a owl:Class ;
    rdfs:label "Home Loan" ;
    rdfs:comment "A real-estate secured mortgage loan." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sbi:securedByCollateral ;
            owl:someValuesFrom sbi:Collateral ],
        sbi:Loan .

sbi:InteractionContext a owl:Class ;
    rdfs:label "Interaction Context" ;
    rdfs:comment "Dynamic context metadata surrounding active interactions." .

sbi:InterestRatePolicy a owl:Class ;
    rdfs:label "Interest Rate Policy" ;
    rdfs:comment "Lending/deposit interest rate ranges." ;
    rdfs:subClassOf sbi:Policy .

sbi:InvestmentProduct a owl:Class ;
    rdfs:label "InvestmentProduct" ;
    rdfs:comment "Wealth management product templates (e.g., Brokerage, Mutual Funds)." ;
    rdfs:subClassOf sbi:BankingProduct .

sbi:JourneyMilestone a owl:Class ;
    rdfs:label "Journey Milestone" ;
    rdfs:comment "Key successes completed along the client journey." .

sbi:JourneyStage a owl:Class ;
    rdfs:label "Journey Stage" ;
    rdfs:comment "Core lifecycle phases (Lead, Onboarded, Advocate)." .

sbi:Lien a owl:Class ;
    rdfs:label "Lien" ;
    rdfs:comment "Legal registry claims held against collateral objects." .

sbi:LoanAccount a owl:Class ;
    rdfs:label "Loan Account" ;
    rdfs:comment "A specific term loan ledger." ;
    rdfs:subClassOf sbi:LendingAccount .

sbi:LocationContext a owl:Class ;
    rdfs:label "Location Context" ;
    rdfs:comment "Geographical and IP parameters." .

sbi:NPSMetric a owl:Class ;
    rdfs:label "NPS Metric" ;
    rdfs:comment "Customer satisfaction surveys and Net Promoter Scores." .

sbi:NotificationChannel a owl:Class ;
    rdfs:label "Notification Channel" ;
    rdfs:comment "Output route identifiers (e.g., SMS, Email, Push)." .

sbi:NotificationTemplate a owl:Class ;
    rdfs:label "Notification Template" ;
    rdfs:comment "Standard texts customized for notification messages." .

sbi:OperationalLog a owl:Class ;
    rdfs:label "Operational Log" ;
    rdfs:comment "Software execution logs tracking system messages." .

sbi:OperationsQueue a owl:Class ;
    rdfs:label "Operations Queue" ;
    rdfs:comment "Manual or automated task buckets waiting for actions." .

sbi:PEPCheckResult a owl:Class ;
    rdfs:label "PEP Check Result" ;
    rdfs:comment "Audit validations confirming if a customer is a PEP." .

sbi:PersonalLoan a owl:Class ;
    rdfs:label "Personal Loan" ;
    rdfs:comment "An unsecured consumer installment loan." ;
    rdfs:subClassOf sbi:Loan .

sbi:PolicyException a owl:Class ;
    rdfs:label "Policy Exception" ;
    rdfs:comment "Authorized deviations from policy guidelines." .

sbi:PortfolioRebalancingAction a owl:Class ;
    rdfs:label "Portfolio Rebalancing Action" ;
    rdfs:comment "Advisory trade directives realigning asset weights." .

sbi:RecommendationAction a owl:Class ;
    rdfs:label "Recommendation Action" ;
    rdfs:comment "Trigger actions linked to dynamic recommendations." .

sbi:RecommendationFeedback a owl:Class ;
    rdfs:label "Recommendation Feedback" ;
    rdfs:comment "Audit tracking customer click/ignore responses." .

sbi:RegulatoryPolicy a owl:Class ;
    rdfs:label "Regulatory Policy" ;
    rdfs:comment "Compliance-aligned operational restrictions." ;
    rdfs:subClassOf sbi:Policy .

sbi:RegulatoryRequirement a owl:Class ;
    rdfs:label "Regulatory Requirement" ;
    rdfs:comment "External regulatory frameworks governed by law." .

sbi:RequestCategory a owl:Class ;
    rdfs:label "Request Category" ;
    rdfs:comment "Routing classification (Card Dispute, Fee Waiver, Address Update)." .

sbi:RequestPriority a owl:Class ;
    rdfs:label "Request Priority" ;
    rdfs:comment "Severity rankings assigned to service tickets." .

sbi:RewardsProgram a owl:Class ;
    rdfs:label "Rewards Program" ;
    rdfs:comment "System tracking customer loyalty points and redemptions." .

sbi:RiskAssessment a owl:Class ;
    rdfs:label "Risk Assessment" ;
    rdfs:comment "Audit tracking the generation run of risk engine scores." .

sbi:RiskFactor a owl:Class ;
    rdfs:label "Risk Factor" ;
    rdfs:comment "Atomic elements driving a customer risk profile score." .

sbi:SLAAgreement a owl:Class ;
    rdfs:label "SLA Agreement" ;
    rdfs:comment "Service Level Agreements bounding resolution durations." .

sbi:SanctionScreeningResult a owl:Class ;
    rdfs:label "Sanction Screening Result" ;
    rdfs:comment "List checks matching customers against watchlist profiles." .

sbi:SavingsAccount a owl:Class ;
    rdfs:label "Savings Account" ;
    rdfs:comment "An interest-bearing deposit account." ;
    rdfs:subClassOf sbi:DepositAccount .

sbi:Segment_HNWI a sbi:CustomerSegment ;
    rdfs:label "High Net Worth Individual Segment" .

sbi:Segment_MassAffluent a sbi:CustomerSegment ;
    rdfs:label "Mass Affluent Segment" .

sbi:Segment_MassRetail a sbi:CustomerSegment ;
    rdfs:label "Mass Retail Segment" .

sbi:SpendingBenchmark a owl:Class ;
    rdfs:label "Spending Benchmark" ;
    rdfs:comment "Peer-group spending averages mapped to demographics." .

sbi:Status_Active a sbi:AccountStatus ;
    rdfs:label "Active Account" .

sbi:Status_Closed a sbi:AccountStatus ;
    rdfs:label "Closed Account" .

sbi:Status_Dormant a sbi:AccountStatus ;
    rdfs:label "Dormant Account" .

sbi:Status_Frozen a sbi:AccountStatus ;
    rdfs:label "Frozen Account" .

sbi:SuspiciousActivityReport a owl:Class ;
    rdfs:label "Suspicious Activity Report" ;
    rdfs:comment "FinCEN-style AML/CTF regulatory filing documents." .

sbi:SystemOutage a owl:Class ;
    rdfs:label "System Outage" ;
    rdfs:comment "Downtime events impacting banking availability." .

sbi:SystemProcess a owl:Class ;
    rdfs:label "System Process" ;
    rdfs:comment "Running software systems, APIs, and batch jobs." .

sbi:SystemRole a owl:Class ;
    rdfs:label "System Role" ;
    rdfs:comment "Security access configurations matching operations queues." .

sbi:TransferTransaction a owl:Class ;
    rdfs:label "Transfer Transaction" ;
    rdfs:comment "Direct fund movement between internal accounts." ;
    rdfs:subClassOf sbi:Transaction .

sbi:TxnStatus_Declined a sbi:TransactionStatus ;
    rdfs:label "Declined Transaction" .

sbi:TxnStatus_Pending a sbi:TransactionStatus ;
    rdfs:label "Pending Transaction" .

sbi:TxnStatus_Settled a sbi:TransactionStatus ;
    rdfs:label "Settled Transaction" .

sbi:UnderwritingPolicy a owl:Class ;
    rdfs:label "Underwriting Policy" ;
    rdfs:comment "Lending criteria policies." ;
    rdfs:subClassOf sbi:Policy .

sbi:Vault a owl:Class ;
    rdfs:label "Vault" ;
    rdfs:comment "Safe deposit boxes and branch cash reserve containment units." .

sbi:VerStatus_Pending a sbi:VerificationStatus ;
    rdfs:label "Pending Verification" .

sbi:VerStatus_Rejected a sbi:VerificationStatus ;
    rdfs:label "Rejected Status" .

sbi:VerStatus_Unverified a sbi:VerificationStatus ;
    rdfs:label "Unverified Status" .

sbi:VerStatus_Verified a sbi:VerificationStatus ;
    rdfs:label "Verified Status" .

sbi:accountId a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "account ID" ;
    rdfs:comment "Unique account UUID." ;
    rdfs:domain sbi:Account ;
    rdfs:range xsd:string .

sbi:alertScore a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "alert score" ;
    rdfs:comment "ML fraud probability (0.00-1.00)." ;
    rdfs:domain sbi:FraudAlert ;
    rdfs:range xsd:decimal .

sbi:amount a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "amount" ;
    rdfs:comment "Transaction amount value." ;
    rdfs:domain sbi:Transaction ;
    rdfs:range xsd:decimal .

sbi:annualIncome a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "annual income" ;
    rdfs:comment "Stated annual salary of customer." ;
    rdfs:domain sbi:IndividualCustomer ;
    rdfs:range xsd:decimal .

sbi:annualRevenue a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "annual revenue" ;
    rdfs:comment "Stated annual revenue of corporate client." ;
    rdfs:domain sbi:CorporateCustomer ;
    rdfs:range xsd:decimal .

sbi:assetCurrentPrice a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "asset current price" ;
    rdfs:comment "Active feed price value of security." ;
    rdfs:domain sbi:InvestmentAsset ;
    rdfs:range xsd:decimal .

sbi:assetTicker a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "asset ticker" ;
    rdfs:comment "Stock exchange listing ticker." ;
    rdfs:domain sbi:InvestmentAsset ;
    rdfs:range xsd:string .

sbi:availableBalance a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "available balance" ;
    rdfs:comment "Spendable balance minus active hold limits." ;
    rdfs:domain sbi:DepositAccount ;
    rdfs:range xsd:decimal .

sbi:balance a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "balance" ;
    rdfs:comment "Core ledger balance of the account." ;
    rdfs:domain sbi:Account ;
    rdfs:range xsd:decimal .

sbi:baseInterestRate a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "base interest rate" ;
    rdfs:comment "Annual percentage rate (APR/APY)." ;
    rdfs:domain sbi:DepositProduct ;
    rdfs:range xsd:decimal .

sbi:creditLimit a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "credit limit" ;
    rdfs:comment "Total approved credit line limit." ;
    rdfs:domain sbi:CreditCardAccount ;
    rdfs:range xsd:decimal .

sbi:customerId a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "customer ID" ;
    rdfs:comment "UUID for legal customer identity." ;
    rdfs:domain sbi:Customer ;
    rdfs:range xsd:string .

sbi:dateOfBirth a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "date of birth" ;
    rdfs:comment "Date of birth of individual customer." ;
    rdfs:domain sbi:IndividualCustomer ;
    rdfs:range xsd:date .

sbi:employeeId a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "employee ID" ;
    rdfs:comment "HR employee profile reference ID." ;
    rdfs:domain sbi:Employee ;
    rdfs:range xsd:string .

sbi:eventId a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "event ID" ;
    rdfs:comment "Event bus message reference ID." ;
    rdfs:domain sbi:BankingEvent ;
    rdfs:range xsd:string .

sbi:eventTimestamp a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "event timestamp" ;
    rdfs:comment "Event generation timestamp." ;
    rdfs:domain sbi:BankingEvent ;
    rdfs:range xsd:dateTime .

sbi:firstName a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "first name" ;
    rdfs:comment "Given name of individual customer." ;
    rdfs:domain sbi:IndividualCustomer ;
    rdfs:range xsd:string .

sbi:fraudLossAmount a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "fraud loss amount" ;
    rdfs:comment "Financial loss logged under fraud case." ;
    rdfs:domain sbi:FraudCase ;
    rdfs:range xsd:decimal .

sbi:healthScoreValue a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "health score value" ;
    rdfs:comment "Calculated wellness index (1-100)." ;
    rdfs:domain sbi:FinancialHealthScore ;
    rdfs:range xsd:integer .

sbi:lastName a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "last name" ;
    rdfs:comment "Surname of individual customer." ;
    rdfs:domain sbi:IndividualCustomer ;
    rdfs:range xsd:string .

sbi:legalName a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "legal name" ;
    rdfs:comment "Registered corporate identity name." ;
    rdfs:domain sbi:CorporateCustomer ;
    rdfs:range xsd:string .

sbi:mccCode a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "MCC code" ;
    rdfs:comment "Standard Merchant Category Code." ;
    rdfs:domain sbi:MerchantCategory ;
    rdfs:range xsd:string .

sbi:merchantId a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "merchant ID" ;
    rdfs:comment "Merchant reference code." ;
    rdfs:domain sbi:Merchant ;
    rdfs:range xsd:string .

sbi:merchantName a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "merchant name" ;
    rdfs:comment "Business trading name." ;
    rdfs:domain sbi:Merchant ;
    rdfs:range xsd:string .

sbi:merchantRiskRating a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "merchant risk rating" ;
    rdfs:comment "Calculated risk score of merchant." ;
    rdfs:domain sbi:Merchant ;
    rdfs:range xsd:integer .

sbi:netWorthClass a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "net worth class" ;
    rdfs:comment "Stated tier of wealth classification." ;
    rdfs:domain sbi:Customer ;
    rdfs:range xsd:string .

sbi:onboardingDate a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "onboarding date" ;
    rdfs:comment "Official registration date of relationship." ;
    rdfs:domain sbi:Customer ;
    rdfs:range xsd:date .

sbi:outstandingPrincipal a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "outstanding principal" ;
    rdfs:comment "Remaining unpaid principal debt." ;
    rdfs:domain sbi:LendingAccount ;
    rdfs:range xsd:decimal .

sbi:productId a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "product ID" ;
    rdfs:comment "Unique product template reference ID." ;
    rdfs:domain sbi:BankingProduct ;
    rdfs:range xsd:string .

sbi:productName a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "product name" ;
    rdfs:comment "Marketing name of product offering." ;
    rdfs:domain sbi:BankingProduct ;
    rdfs:range xsd:string .

sbi:recommendationConfidence a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "recommendation confidence" ;
    rdfs:comment "ML model predictive confidence." ;
    rdfs:domain sbi:Recommendation ;
    rdfs:range xsd:decimal .

sbi:riskToleranceScore a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "risk tolerance score" ;
    rdfs:comment "Risk tolerance assessment score (1-100)." ;
    rdfs:domain sbi:Customer ;
    rdfs:range xsd:integer .

sbi:sentimentScore a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "sentiment score" ;
    rdfs:comment "Calculated interaction sentiment (-1.0 to 1.0)." ;
    rdfs:domain sbi:InteractionHistory ;
    rdfs:range xsd:decimal .

sbi:targetAmount a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "target amount" ;
    rdfs:comment "Target savings goal." ;
    rdfs:domain sbi:FinancialGoal ;
    rdfs:range xsd:decimal .

sbi:targetDate a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "target date" ;
    rdfs:comment "Target goal completion date." ;
    rdfs:domain sbi:FinancialGoal ;
    rdfs:range xsd:date .

sbi:timestamp a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "timestamp" ;
    rdfs:comment "Time transaction cleared." ;
    rdfs:domain sbi:Transaction ;
    rdfs:range xsd:dateTime .

sbi:transactionId a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "transaction ID" ;
    rdfs:comment "Unique ledger transaction ID." ;
    rdfs:domain sbi:Transaction ;
    rdfs:range xsd:string .

sbi:verificationDate a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "verification date" ;
    rdfs:comment "Date KYC record audit completed." ;
    rdfs:domain sbi:KYCRecord ;
    rdfs:range xsd:date .

sbi:DepositProduct a owl:Class ;
    rdfs:label "Deposit Product" ;
    rdfs:comment "Asset-gathering product templates (e.g., Savings, Checking, CDs)." ;
    rdfs:subClassOf sbi:BankingProduct .

sbi:Document a owl:Class ;
    rdfs:label "Document" ;
    rdfs:comment "Digital files supporting legal contracts or verification." .

sbi:FraudCase a owl:Class ;
    rdfs:label "Fraud Case" ;
    rdfs:comment "Active operations investigation file for suspect transactions." .

sbi:LendingProduct a owl:Class ;
    rdfs:label "Lending Product" ;
    rdfs:comment "Credit-granting product templates (e.g., Mortgages, Personal Loans)." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sbi:minimumCreditScore ;
            owl:someValuesFrom xsd:integer ],
        sbi:BankingProduct .

sbi:alertedTransaction a owl:ObjectProperty ;
    rdfs:label "alerted transaction" ;
    rdfs:comment "Inverse of triggersFraudAlert." ;
    rdfs:domain sbi:FraudAlert ;
    rdfs:range sbi:Transaction ;
    owl:inverseOf sbi:triggersFraudAlert .

sbi:belongsToCategory a owl:ObjectProperty ;
    rdfs:label "belongs to category" ;
    rdfs:comment "Links a merchant to their MCC category." ;
    rdfs:domain sbi:Merchant ;
    rdfs:range sbi:MerchantCategory ;
    owl:inverseOf sbi:containsMerchant .

sbi:belongsToSegment a owl:ObjectProperty ;
    rdfs:label "belongs to segment" ;
    rdfs:comment "Links a customer to their service segment." ;
    rdfs:domain sbi:Customer ;
    rdfs:range sbi:CustomerSegment ;
    owl:inverseOf sbi:segmentHasCustomer .

sbi:beneficialOwnerOf a owl:ObjectProperty ;
    rdfs:label "beneficial owner of" ;
    rdfs:comment "Inverse of hasBeneficialOwner." ;
    rdfs:domain sbi:IndividualCustomer ;
    rdfs:range sbi:CorporateCustomer ;
    owl:inverseOf sbi:hasBeneficialOwner .

sbi:beneficiaryOf a owl:ObjectProperty ;
    rdfs:label "beneficiary of" ;
    rdfs:comment "Inverse of hasBeneficiary." ;
    rdfs:domain sbi:IndividualCustomer ;
    rdfs:range sbi:Account ;
    owl:inverseOf sbi:hasBeneficiary .

sbi:categorizedAs a owl:ObjectProperty ;
    rdfs:label "categorized as" ;
    rdfs:comment "Links a transaction to its category." ;
    rdfs:domain sbi:Transaction ;
    rdfs:range sbi:TransactionCategorization ;
    owl:inverseOf sbi:categorizes .

sbi:categorizes a owl:ObjectProperty ;
    rdfs:label "categorizes" ;
    rdfs:comment "Inverse of categorizedAs." ;
    rdfs:domain sbi:TransactionCategorization ;
    rdfs:range sbi:Transaction ;
    owl:inverseOf sbi:categorizedAs .

sbi:channelUsedBy a owl:ObjectProperty ;
    rdfs:label "channel used by" ;
    rdfs:comment "Inverse of initiatedVia." ;
    rdfs:domain sbi:TransactionChannel ;
    rdfs:range sbi:Transaction ;
    owl:inverseOf sbi:initiatedVia .

sbi:constrainsProduct a owl:ObjectProperty ;
    rdfs:label "constrains product" ;
    rdfs:comment "Inverse of productConstrainedByPolicy." ;
    rdfs:domain sbi:Policy ;
    rdfs:range sbi:BankingProduct ;
    owl:inverseOf sbi:productConstrainedByPolicy .

sbi:containsMerchant a owl:ObjectProperty ;
    rdfs:label "contains merchant" ;
    rdfs:comment "Inverse of belongsToCategory." ;
    rdfs:domain sbi:MerchantCategory ;
    rdfs:range sbi:Merchant ;
    owl:inverseOf sbi:belongsToCategory .

sbi:containsOutlet a owl:ObjectProperty ;
    rdfs:label "contains outlet" ;
    rdfs:comment "Inverse of partOfBrand." ;
    rdfs:domain sbi:MerchantBrand ;
    rdfs:range sbi:Merchant ;
    owl:inverseOf sbi:partOfBrand .

sbi:containsPortfolio a owl:ObjectProperty ;
    rdfs:label "contains portfolio" ;
    rdfs:comment "Links an investment account to its portfolio." ;
    rdfs:domain sbi:InvestmentAccount ;
    rdfs:range sbi:InvestmentPortfolio ;
    owl:inverseOf sbi:portfolioInAccount .

sbi:employedBy a owl:ObjectProperty ;
    rdfs:label "employed by" ;
    rdfs:comment "Links an individual customer to their corporate employer." ;
    rdfs:domain sbi:IndividualCustomer ;
    rdfs:range sbi:CorporateCustomer ;
    owl:inverseOf sbi:employs .

sbi:employeeAssignedToBranch a owl:ObjectProperty ;
    rdfs:label "employee assigned to branch" ;
    rdfs:comment "Links employees to their branch location." ;
    rdfs:domain sbi:Employee ;
    rdfs:range sbi:Branch ;
    owl:inverseOf sbi:employeesAtBranch .

sbi:employeesAtBranch a owl:ObjectProperty ;
    rdfs:label "employees at branch" ;
    rdfs:comment "Inverse of employeeAssignedToBranch." ;
    rdfs:domain sbi:Branch ;
    rdfs:range sbi:Employee ;
    owl:inverseOf sbi:employeeAssignedToBranch .

sbi:employs a owl:ObjectProperty ;
    rdfs:label "employs" ;
    rdfs:comment "Inverse of employedBy." ;
    rdfs:domain sbi:CorporateCustomer ;
    rdfs:range sbi:IndividualCustomer ;
    owl:inverseOf sbi:employedBy .

sbi:fundedByAccount a owl:ObjectProperty ;
    rdfs:label "funded by account" ;
    rdfs:comment "Links a financial goal to its funding account." ;
    rdfs:domain sbi:FinancialGoal ;
    rdfs:range sbi:Account ;
    owl:inverseOf sbi:fundsGoal .

sbi:fundsGoal a owl:ObjectProperty ;
    rdfs:label "funds goal" ;
    rdfs:comment "Inverse of fundedByAccount." ;
    rdfs:domain sbi:Account ;
    rdfs:range sbi:FinancialGoal ;
    owl:inverseOf sbi:fundedByAccount .

sbi:governedByRules a owl:ObjectProperty ;
    rdfs:label "governed by rules" ;
    rdfs:comment "Links a banking product to its parameters." ;
    rdfs:domain sbi:BankingProduct ;
    rdfs:range sbi:ProductRules ;
    owl:inverseOf sbi:rulesApplyTo .

sbi:hasAccountStatus a owl:ObjectProperty ;
    rdfs:label "has account status" ;
    rdfs:comment "Links an account to its active state." ;
    rdfs:domain sbi:Account ;
    rdfs:range sbi:AccountStatus ;
    owl:inverseOf sbi:statusOfAccount .

sbi:hasBeneficialOwner a owl:ObjectProperty ;
