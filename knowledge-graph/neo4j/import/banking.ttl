    rdfs:domain sbi:CorporateCustomer ;
    rdfs:range sbi:IndividualCustomer ;
    owl:inverseOf sbi:beneficialOwnerOf .

sbi:hasBeneficiary a owl:ObjectProperty ;
    rdfs:label "has beneficiary" ;
    rdfs:comment "Links an account to pay-on-death beneficiaries." ;
    rdfs:domain sbi:Account ;
    rdfs:range sbi:IndividualCustomer ;
    owl:inverseOf sbi:beneficiaryOf .

sbi:hasCard a owl:ObjectProperty ;
    rdfs:label "has card" ;
    rdfs:comment "Inverse of linkedToAccount." ;
    rdfs:domain sbi:CreditCardAccount ;
    rdfs:range sbi:CreditCard ;
    owl:inverseOf sbi:linkedToAccount .

sbi:hasHouseholdMember a owl:ObjectProperty ;
    rdfs:label "has household member" ;
    rdfs:comment "Inverse of memberOfHousehold." ;
    rdfs:domain sbi:CustomerHousehold ;
    rdfs:range sbi:IndividualCustomer ;
    owl:inverseOf sbi:memberOfHousehold .

sbi:hasInteractionLog a owl:ObjectProperty ;
    rdfs:label "has interaction log" ;
    rdfs:comment "Links a customer to their communication logs." ;
    rdfs:domain sbi:Customer ;
    rdfs:range sbi:InteractionHistory ;
    owl:inverseOf sbi:loggedForCustomer .

sbi:hasKYCRecord a owl:ObjectProperty ;
    rdfs:label "has KYC record" ;
