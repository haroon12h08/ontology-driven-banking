    rdfs:domain sbi:Customer ;
    rdfs:range sbi:KYCRecord ;
    owl:inverseOf sbi:kycOfCustomer .

sbi:hasRiskProfile a owl:ObjectProperty ;
    rdfs:label "has risk profile" ;
    rdfs:comment "Links a customer to their active risk profile." ;
    rdfs:domain sbi:Customer ;
    rdfs:range sbi:RiskProfile ;
    owl:inverseOf sbi:riskOfCustomer .

sbi:hasTransactionStatus a owl:ObjectProperty ;
    rdfs:label "has transaction status" ;
    rdfs:comment "Links a transaction to its clearing state." ;
    rdfs:domain sbi:Transaction ;
    rdfs:range sbi:TransactionStatus ;
    owl:inverseOf sbi:statusOfTransaction .

sbi:healthOfCustomer a owl:ObjectProperty ;
    rdfs:label "health of customer" ;
    rdfs:comment "Inverse of monitorsHealth." ;
    rdfs:domain sbi:FinancialHealthScore ;
    rdfs:range sbi:Customer ;
    owl:inverseOf sbi:monitorsHealth .

sbi:heldInPortfolio a owl:ObjectProperty ;
    rdfs:label "held in portfolio" ;
    rdfs:comment "Inverse of holdsAssetHolding." ;
    rdfs:domain sbi:InvestmentAsset ;
    rdfs:range sbi:InvestmentPortfolio ;
    owl:inverseOf sbi:holdsAssetHolding .

sbi:holdsAssetHolding a owl:ObjectProperty ;
    rdfs:label "holds asset holding" ;
    rdfs:comment "Links a portfolio to its specific assets." ;
    rdfs:domain sbi:InvestmentPortfolio ;
    rdfs:range sbi:InvestmentAsset ;
    owl:inverseOf sbi:heldInPortfolio .

sbi:initiatedVia a owl:ObjectProperty ;
    rdfs:label "initiated via" ;
    rdfs:comment "Links a transaction to the channel used." ;
    rdfs:domain sbi:Transaction ;
    rdfs:range sbi:TransactionChannel ;
    owl:inverseOf sbi:channelUsedBy .

sbi:instantiatesProduct a owl:ObjectProperty ;
    rdfs:label "instantiates product" ;
    rdfs:comment "Links a ledger account to its product template." ;
    rdfs:domain sbi:Account ;
    rdfs:range sbi:BankingProduct ;
    owl:inverseOf sbi:productInstantiatedBy .

sbi:kycOfCustomer a owl:ObjectProperty ;
    rdfs:label "kyc of customer" ;
    rdfs:comment "Inverse of hasKYCRecord." ;
    rdfs:domain sbi:KYCRecord ;
    rdfs:range sbi:Customer ;
    owl:inverseOf sbi:hasKYCRecord .

sbi:linkedToAccount a owl:ObjectProperty ;
    rdfs:label "linked to account" ;
    rdfs:comment "Links a credit card to its credit account." ;
    rdfs:domain sbi:CreditCard ;
    rdfs:range sbi:CreditCardAccount ;
    owl:inverseOf sbi:hasCard .

sbi:loggedForCustomer a owl:ObjectProperty ;
    rdfs:label "logged for customer" ;
    rdfs:comment "Inverse of hasInteractionLog." ;
    rdfs:domain sbi:InteractionHistory ;
    rdfs:range sbi:Customer ;
    owl:inverseOf sbi:hasInteractionLog .

sbi:managedByRM a owl:ObjectProperty ;
    rdfs:label "managed by RM" ;
    rdfs:comment "Inverse of managesCustomer." ;
    rdfs:domain sbi:Customer ;
    rdfs:range sbi:RelationshipManager ;
    owl:inverseOf sbi:managesCustomer .

sbi:managesCustomer a owl:ObjectProperty ;
    rdfs:label "manages customer" ;
    rdfs:comment "Links a Relationship Manager to their assigned clients." ;
    rdfs:domain sbi:RelationshipManager ;
    rdfs:range sbi:Customer ;
    owl:inverseOf sbi:managedByRM .

sbi:memberOfHousehold a owl:ObjectProperty ;
    rdfs:label "member of household" ;
    rdfs:comment "Links an individual to a household." ;
    rdfs:domain sbi:IndividualCustomer ;
    rdfs:range sbi:CustomerHousehold ;
    owl:inverseOf sbi:hasHouseholdMember .

sbi:minimumCreditScore a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "minimum credit score" ;
    rdfs:comment "Underwriting constraint score required to borrow." ;
    rdfs:domain sbi:LendingProduct ;
    rdfs:range xsd:integer .

sbi:monitorsHealth a owl:ObjectProperty ;
    rdfs:label "monitors health" ;
    rdfs:comment "Links a customer to their financial health scores." ;
    rdfs:domain sbi:Customer ;
    rdfs:range sbi:FinancialHealthScore ;
    owl:inverseOf sbi:healthOfCustomer .

sbi:notificationSentTo a owl:ObjectProperty ;
    rdfs:label "notification sent to" ;
    rdfs:comment "Inverse of receivesNotification." ;
    rdfs:domain sbi:Notification ;
    rdfs:range sbi:Customer ;
    owl:inverseOf sbi:receivesNotification .

sbi:occursAtMerchant a owl:ObjectProperty ;
    rdfs:label "occurs at merchant" ;
    rdfs:comment "Links a transaction to the receiving merchant." ;
    rdfs:domain sbi:Transaction ;
    rdfs:range sbi:Merchant ;
    owl:inverseOf sbi:processesTransaction .

sbi:originatesTransaction a owl:ObjectProperty ;
    rdfs:label "originates transaction" ;
    rdfs:comment "Links an account to outgoing fund transactions." ;
    rdfs:domain sbi:Account ;
    rdfs:range sbi:Transaction ;
    owl:inverseOf sbi:originatingAccount .

sbi:originatingAccount a owl:ObjectProperty ;
    rdfs:label "originating account" ;
    rdfs:comment "Inverse of originatesTransaction." ;
    rdfs:domain sbi:Transaction ;
    rdfs:range sbi:Account ;
    owl:inverseOf sbi:originatesTransaction .

sbi:ownedBy a owl:ObjectProperty ;
    rdfs:label "owned by" ;
    rdfs:comment "Inverse of ownsAccount." ;
    rdfs:domain sbi:Account ;
    rdfs:range sbi:Customer ;
    owl:inverseOf sbi:ownsAccount .

sbi:partOfBrand a owl:ObjectProperty ;
    rdfs:label "part of brand" ;
    rdfs:comment "Links a merchant to its parent brand." ;
    rdfs:domain sbi:Merchant ;
    rdfs:range sbi:MerchantBrand ;
    owl:inverseOf sbi:containsOutlet .

sbi:portfolioInAccount a owl:ObjectProperty ;
    rdfs:label "portfolio in account" ;
    rdfs:comment "Inverse of containsPortfolio." ;
    rdfs:domain sbi:InvestmentPortfolio ;
    rdfs:range sbi:InvestmentAccount ;
    owl:inverseOf sbi:containsPortfolio .

sbi:processesTransaction a owl:ObjectProperty ;
    rdfs:label "processes transaction" ;
    rdfs:comment "Inverse of occursAtMerchant." ;
    rdfs:domain sbi:Merchant ;
    rdfs:range sbi:Transaction ;
    owl:inverseOf sbi:occursAtMerchant .

sbi:productConstrainedByPolicy a owl:ObjectProperty ;
    rdfs:label "product constrained by policy" ;
    rdfs:comment "Links a banking product to risk policies." ;
    rdfs:domain sbi:BankingProduct ;
    rdfs:range sbi:Policy ;
    owl:inverseOf sbi:constrainsProduct .

sbi:productInstantiatedBy a owl:ObjectProperty ;
    rdfs:label "product instantiated by" ;
    rdfs:comment "Inverse of instantiatesProduct." ;
    rdfs:domain sbi:BankingProduct ;
    rdfs:range sbi:Account ;
    owl:inverseOf sbi:instantiatesProduct .

sbi:pursuedBy a owl:ObjectProperty ;
    rdfs:label "pursued by" ;
    rdfs:comment "Inverse of pursuesGoal." ;
    rdfs:domain sbi:FinancialGoal ;
    rdfs:range sbi:Customer ;
    owl:inverseOf sbi:pursuesGoal .

sbi:pursuesGoal a owl:ObjectProperty ;
    rdfs:label "pursues goal" ;
    rdfs:comment "Links a customer to their financial goal." ;
    rdfs:domain sbi:Customer ;
    rdfs:range sbi:FinancialGoal ;
    owl:inverseOf sbi:pursuedBy .

sbi:receivesNotification a owl:ObjectProperty ;
    rdfs:label "receives notification" ;
    rdfs:comment "Links a customer to outgoing alerts." ;
    rdfs:domain sbi:Customer ;
    rdfs:range sbi:Notification ;
    owl:inverseOf sbi:notificationSentTo .

sbi:receivesRecommendation a owl:ObjectProperty ;
    rdfs:label "receives recommendation" ;
    rdfs:comment "Links a customer to recommender alerts." ;
    rdfs:domain sbi:Customer ;
    rdfs:range sbi:Recommendation ;
    owl:inverseOf sbi:recommendedToCustomer .

sbi:receivesTransaction a owl:ObjectProperty ;
    rdfs:label "receives transaction" ;
    rdfs:comment "Links an account to incoming fund transactions." ;
    rdfs:domain sbi:Account ;
    rdfs:range sbi:Transaction ;
    owl:inverseOf sbi:receivingAccount .

sbi:receivingAccount a owl:ObjectProperty ;
    rdfs:label "receiving account" ;
    rdfs:comment "Inverse of receivesTransaction." ;
    rdfs:domain sbi:Transaction ;
    rdfs:range sbi:Account ;
    owl:inverseOf sbi:receivesTransaction .

sbi:recommendedToCustomer a owl:ObjectProperty ;
    rdfs:label "recommended to customer" ;
    rdfs:comment "Inverse of receivesRecommendation." ;
    rdfs:domain sbi:Recommendation ;
    rdfs:range sbi:Customer ;
    owl:inverseOf sbi:receivesRecommendation .

sbi:riskOfCustomer a owl:ObjectProperty ;
    rdfs:label "risk of customer" ;
    rdfs:comment "Inverse of hasRiskProfile." ;
    rdfs:domain sbi:RiskProfile ;
    rdfs:range sbi:Customer ;
    owl:inverseOf sbi:hasRiskProfile .

sbi:rulesApplyTo a owl:ObjectProperty ;
    rdfs:label "rules apply to" ;
    rdfs:comment "Inverse of governedByRules." ;
    rdfs:domain sbi:ProductRules ;
    rdfs:range sbi:BankingProduct ;
    owl:inverseOf sbi:governedByRules .

sbi:securesLoan a owl:ObjectProperty ;
    rdfs:label "secures loan" ;
    rdfs:comment "Inverse of securedByCollateral." ;
    rdfs:domain sbi:Collateral ;
    rdfs:range sbi:Loan ;
    owl:inverseOf sbi:securedByCollateral .

sbi:segmentHasCustomer a owl:ObjectProperty ;
    rdfs:label "segment has customer" ;
    rdfs:comment "Inverse of belongsToSegment." ;
    rdfs:domain sbi:CustomerSegment ;
    rdfs:range sbi:Customer ;
    owl:inverseOf sbi:belongsToSegment .

sbi:statusOfAccount a owl:ObjectProperty ;
    rdfs:label "status of account" ;
    rdfs:comment "Inverse of hasAccountStatus." ;
    rdfs:domain sbi:AccountStatus ;
    rdfs:range sbi:Account ;
    owl:inverseOf sbi:hasAccountStatus .

sbi:statusOfTransaction a owl:ObjectProperty ;
    rdfs:label "status of transaction" ;
    rdfs:comment "Inverse of hasTransactionStatus." ;
    rdfs:domain sbi:TransactionStatus ;
    rdfs:range sbi:Transaction ;
    owl:inverseOf sbi:hasTransactionStatus .

sbi:submitsRequest a owl:ObjectProperty ;
    rdfs:label "submits request" ;
    rdfs:comment "Links a customer to their service request ticket." ;
    rdfs:domain sbi:Customer ;
    rdfs:range sbi:ServiceRequest ;
    owl:inverseOf sbi:submittedByCustomerRequest .

sbi:submittedByCustomerRequest a owl:ObjectProperty ;
    rdfs:label "submitted by customer request" ;
    rdfs:comment "Inverse of submitsRequest." ;
    rdfs:domain sbi:ServiceRequest ;
    rdfs:range sbi:Customer ;
    owl:inverseOf sbi:submitsRequest .

sbi:triggersFraudAlert a owl:ObjectProperty ;
    rdfs:label "triggers fraud alert" ;
    rdfs:comment "Links a transaction to a fraud alert." ;
    rdfs:domain sbi:Transaction ;
    rdfs:range sbi:FraudAlert ;
    owl:inverseOf sbi:alertedTransaction .

sbi:verifiesKYC a owl:ObjectProperty ;
    rdfs:label "verifies KYC" ;
    rdfs:comment "Inverse of reliesOnDocument." ;
    rdfs:domain sbi:IdentityDocument ;
    rdfs:range sbi:KYCRecord ;
    owl:inverseOf sbi:reliesOnDocument .

sbi:BankingEvent a owl:Class ;
    rdfs:label "Banking Event" ;
    rdfs:comment "System event broker logs tracking core data changes." .

sbi:Branch a owl:Class ;
    rdfs:label "Branch" ;
    rdfs:comment "Physical brick-and-mortar office buildings." .

sbi:CreditCard a owl:Class ;
    rdfs:label "Credit Card" ;
    rdfs:comment "Plastic or virtual physical card vehicle." .

sbi:CustomerHousehold a owl:Class ;
    rdfs:label "Customer Household" ;
    rdfs:comment "A semantic grouping of individuals sharing a residency or shared financial goals." .

sbi:InvestmentAccount a owl:Class ;
    rdfs:label "Investment Account" ;
    rdfs:comment "A wealth management account holding securities." ;
    rdfs:subClassOf sbi:Account .

sbi:MerchantBrand a owl:Class ;
    rdfs:label "Merchant Brand" ;
    rdfs:comment "Parent brand tree matching multiple merchant outlets." .

sbi:Notification a owl:Class ;
    rdfs:label "Notification" ;
    rdfs:comment "Outgoing alerts dispatched to client channels." .

sbi:ProductRules a owl:Class ;
    rdfs:label "Product Rules" ;
    rdfs:comment "Operational constraints, fee tables, and interest policies for a product." .

sbi:RelationshipManager a owl:Class ;
    rdfs:label "Relationship Manager" ;
    rdfs:comment "Wealth management and corporate accounts staff advisors." ;
    rdfs:subClassOf sbi:Employee .

sbi:RiskProfile a owl:Class ;
    rdfs:label "Risk Profile" ;
    rdfs:comment "Aggregated risk indicators associated with a customer." .

sbi:ServiceRequest a owl:Class ;
    rdfs:label "Service Request" ;
    rdfs:comment "A customer service ticket requiring operational resolution." .

sbi:TransactionCategorization a owl:Class ;
    rdfs:label "Transaction Categorization" ;
    rdfs:comment "Spending classification categories (e.g., Groceries, Rent)." .

sbi:TransactionChannel a owl:Class ;
    rdfs:label "Transaction Channel" ;
    rdfs:comment "The medium used to initiate a transaction (Mobile, ATM, POS, Branch)." .

sbi:ownsAccount a owl:ObjectProperty ;
    rdfs:label "owns account" ;
    rdfs:comment "Links a customer to their financial accounts." ;
    rdfs:domain sbi:Customer ;
    rdfs:range sbi:Account ;
    owl:inverseOf sbi:ownedBy .

sbi:reliesOnDocument a owl:ObjectProperty ;
    rdfs:label "relies on document" ;
    rdfs:comment "Links a KYC record to verifying documents." ;
    rdfs:domain sbi:KYCRecord ;
    rdfs:range sbi:IdentityDocument ;
    owl:inverseOf sbi:verifiesKYC .

sbi:securedByCollateral a owl:ObjectProperty ;
    rdfs:label "secured by collateral" ;
    rdfs:comment "Links a loan to pledged backing collateral." ;
    rdfs:domain sbi:Loan ;
    rdfs:range sbi:Collateral ;
    owl:inverseOf sbi:securesLoan .

sbi:Collateral a owl:Class ;
    rdfs:label "Collateral" ;
    rdfs:comment "An asset pledged by a borrower to secure a loan." .

sbi:CreditCardAccount a owl:Class ;
    rdfs:label "Credit Card Account" ;
    rdfs:comment "A revolving credit account ledger." ;
    rdfs:subClassOf sbi:LendingAccount .

sbi:DepositAccount a owl:Class ;
    rdfs:label "Deposit Account" ;
    rdfs:comment "An account holding customer checking or savings balances." ;
    rdfs:subClassOf sbi:Account .

sbi:FinancialHealthScore a owl:Class ;
    rdfs:label "Financial Health Score" ;
    rdfs:comment "Calculated rating representing customer cash flow wellness." .

sbi:FraudAlert a owl:Class ;
    rdfs:label "Fraud Alert" ;
    rdfs:comment "Real-time automated warnings flagged by ML and rule engines." .

sbi:IdentityDocument a owl:Class ;
    rdfs:label "Identity Document" ;
    rdfs:comment "Official identity files (Passports, Utility Bills, Tax Filings)." ;
    rdfs:subClassOf sbi:Document .

sbi:InteractionHistory a owl:Class ;
    rdfs:label "Interaction History" ;
    rdfs:comment "Logs mapping all communications and touchpoints with clients." .

sbi:LendingAccount a owl:Class ;
    rdfs:label "Lending Account" ;
    rdfs:comment "A liability account tracking outstanding credit debt." ;
    rdfs:subClassOf sbi:Account .

sbi:MerchantCategory a owl:Class ;
    rdfs:label "Merchant Category" ;
    rdfs:comment "Classification of business types matching Merchant Category Codes (MCC)." .

sbi:Recommendation a owl:Class ;
    rdfs:label "Recommendation" ;
    rdfs:comment "Advisory prompts and product cross-sell outputs." .

sbi:Employee a owl:Class ;
    rdfs:label "Employee" ;
    rdfs:comment "Core staff members of the financial institution." .

sbi:InvestmentAsset a owl:Class ;
    rdfs:label "Investment Asset" ;
    rdfs:comment "A market-tradable security (e.g., Stock, Bond, Mutual Fund)." .

sbi:InvestmentPortfolio a owl:Class ;
    rdfs:label "Investment Portfolio" ;
    rdfs:comment "A managed grouping of securities aligned to a specific strategy." .

sbi:VerificationStatus a owl:Class ;
    rdfs:label "Verification Status" ;
    rdfs:comment "States of identity validation audits." .

sbi:CustomerSegment a owl:Class ;
    rdfs:label "Customer Segment" ;
    rdfs:comment "Controlled vocabulary defining relationship tiers (e.g., Mass Retail, HNWI)." .

sbi:KYCRecord a owl:Class ;
    rdfs:label "KYC Record" ;
    rdfs:comment "Customer identification audit registry tracking verification." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sbi:reliesOnDocument ;
            owl:someValuesFrom sbi:IdentityDocument ] .

sbi:Loan a owl:Class ;
    rdfs:label "Loan" ;
    rdfs:comment "A debt contract representing borrowed principal and interest constraints." .

sbi:TransactionStatus a owl:Class ;
    rdfs:label "Transaction Status" ;
    rdfs:comment "Clearing states (Pending, Settled, Declined, Reversed)." .

sbi:AccountStatus a owl:Class ;
    rdfs:label "Account Status" ;
    rdfs:comment "Explicit state designations (Active, Frozen, Dormant, Closed)." .

sbi:CorporateCustomer a owl:Class ;
    rdfs:label "Corporate Customer" ;
    rdfs:comment "A registered business, trust, or legal entity client." ;
    rdfs:subClassOf sbi:Customer .

sbi:FinancialGoal a owl:Class ;
    rdfs:label "Financial Goal" ;
    rdfs:comment "A customer-defined target objective with target dates and amounts." .

sbi:Policy a owl:Class ;
    rdfs:label "Policy" ;
    rdfs:comment "Internal policies setting operational bounds." .

sbi:Merchant a owl:Class ;
    rdfs:label "Merchant" ;
    rdfs:comment "A business terminal receiving transaction expenditures." .

sbi:BankingProduct a owl:Class ;
    rdfs:label "Banking Product" ;
    rdfs:comment "Abstract product offering templates defining rules, interest rates, and fees." .

sbi:IndividualCustomer a owl:Class ;
    rdfs:label "Individual Customer" ;
    rdfs:comment "A natural person who holds banking relationships." ;
    rdfs:subClassOf sbi:Customer .

sbi:Account a owl:Class ;
    rdfs:label "Account" ;
    rdfs:comment "An instantiated ledger contract owned by a customer representing a financial balance." .

sbi:Transaction a owl:Class ;
    rdfs:label "Transaction" ;
    rdfs:comment "An immutable ledger entry recording financial movement." .

sbi:Customer a owl:Class ;
    rdfs:label "Customer" ;
    rdfs:comment "Abstract base class for any banking client (Individual or Corporate)." ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty sbi:ownsAccount ;
            owl:someValuesFrom sbi:Account ] .

